# Social Warehouse — Environment Variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# --- PostgreSQL / PostGIS ---
POSTGRES_HOST=postgis
POSTGRES_DB=gis
POSTGRES_USER=socialwarehouse
POSTGRES_PASSWORD=CHANGEME
POSTGRES_HOST_AUTH_METHOD=scram-sha-256
POSTGRES_PORT=54324

# --- Docker build ---
UBUNTU_BASE_IMAGE=ubuntu:22.04
PYTHON_VENV_PATH=/opt/venv

# --- Spark ---
SPARK_NO_DAEMONIZE=true

# --- Census data (used by swh CLI) ---
CENSUS_YEAR=2023
CENSUS_CONGRESS_NUMBER=118
# Comma-separated state FIPS codes, or "all"
CENSUS_STATES=all
